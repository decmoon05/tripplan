{
  "name": "tripwise",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "api": "npm run dev --workspace=packages/api",
    "dev": "concurrently \"npm run api\" \"npm run mobile\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
