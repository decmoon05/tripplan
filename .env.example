# ==============================
# TripWise 환경변수 템플릿
# 이 파일을 복사해서 .env 로 저장 후 값 입력
# .env 는 절대 커밋하지 말 것
# ==============================

# 서버 설정
PORT=3000
NODE_ENV=development

# Supabase (PostgreSQL)
# https://supabase.com 에서 프로젝트 생성 후 Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Anthropic Claude API
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# Google Places API
# https://console.cloud.google.com 에서 발급
GOOGLE_PLACES_API_KEY=AIza...

# JWT 시크릿 (32자 이상 랜덤 문자열)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here

# Upstash Redis (선택, Phase 1에서는 비워도 됨)
# https://console.upstash.com 에서 발급
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...
