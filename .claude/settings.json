{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-edit-check.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "(?i)(backend|api|server|route|database|db|prisma|endpoint|middleware|auth|jwt|redis|postgresql|백엔드|서버|데이터베이스)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== [키워드 감지: 백엔드] 매뉴얼 로드 ===' && cat docs/manuals/BACKEND_MANUAL.md"
          }
        ]
      },
      {
        "matcher": "(?i)(frontend|component|screen|react native|expo|ui|화면|컴포넌트|navigation|style|zustand|query|프론트|모바일)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== [키워드 감지: 프론트엔드] 매뉴얼 로드 ===' && cat docs/manuals/FRONTEND_MANUAL.md"
          }
        ]
      },
      {
        "matcher": "(?i)(\\bai\\b|claude|llm|recommendation|추천|personali|프로파일|profile|google places|여행지 추천|프롬프트|prompt)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== [키워드 감지: AI 통합] 매뉴얼 로드 ===' && cat docs/manuals/AI_INTEGRATION_MANUAL.md"
          }
        ]
      },
      {
        "matcher": "(?i)(기능 추가|새로운 기능|새 기능|feature|implement|새 화면|phase|단계|구현)",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== [의도 감지: 기능 추가] Phase 범위 확인 ===' && head -100 docs/00_PROJECT_PLAN.md"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== 현재 TODO ===' && cat docs/02_TODO.md"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/track-file.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quality-check.js"
          }
        ]
      }
    ]
  }
}
